# Local PostgreSQL:
# DATABASE_URL=postgresql+psycopg://nspv:nspv@localhost:5432/nspv

# Supabase PostgreSQL:
# Recommended for local IPv4 networks: use the Session Pooler connection string from
# Supabase Project Settings > Database > Connection string > Session pooler.
# URL-encode special characters in the password.
DATABASE_URL=postgresql+psycopg://postgres.ntwdxwogqqkxrlauejth:[URL_ENCODED_DB_PASSWORD]@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres

# Direct connection, only if your network supports IPv6:
# DATABASE_URL=postgresql+psycopg://postgres:[URL_ENCODED_DB_PASSWORD]@db.ntwdxwogqqkxrlauejth.supabase.co:5432/postgres

FRONTEND_ORIGIN=http://localhost:3000

# Scraper provider options:
# mock, playwright, brightdata
SCRAPER_PROVIDER=mock

# Change this in every non-local environment.
JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# See ../docs/deployment.md for all environment variables.
